{
  "name": "pathwrite",
  "private": true,
  "version": "0.1.0",
  "license": "MIT",
  "description": "Headless path engine with Angular, React, and Vue adapters",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/richardadalton/pathwrite.git"
  },
  "workspaces": [
    "packages/*",
    "apps/shared-workflows/*",
    "apps/angular-demos/*",
    "apps/react-demos/*",
    "apps/react-native-demos/*",
    "apps/svelte-demos/*",
    "apps/vue-demos/*"
  ],
  "scripts": {
    "build": "npm run build -w packages/core && npm run build -w packages/react-adapter && npm run build -w packages/react-native-adapter && npm run build -w packages/vue-adapter && npm run build -w packages/store && npm run build -w packages/svelte-adapter && npm run build -w packages/angular-adapter && npm run build -w @daltonr/pathwrite-demo-workflow-job-application",
    "clean": "npm run clean -ws --if-present && rm -rf packages/*/dist packages/*/*.tsbuildinfo",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublish:check": "npm run clean && npm run build && npm test",
    "release": "npm run prepublish:check && changeset publish",
    "changeset": "changeset",
    "smoke:demos": "node ./scripts/smoke-demos.mjs",
    "version": "changeset version",
    "publish:dry": "npm run prepublish:check && npm publish --dry-run -w packages/core && npm publish --dry-run -w packages/store && npm publish --dry-run -w packages/angular-adapter && npm publish --dry-run -w packages/react-adapter && npm publish --dry-run -w packages/react-native-adapter && npm publish --dry-run -w packages/vue-adapter && npm publish --dry-run -w packages/svelte-adapter",
    "publish:all": "npm run prepublish:check && npm publish -w packages/core && npm publish -w packages/store && npm publish -w packages/angular-adapter && npm publish -w packages/react-adapter && npm publish -w packages/react-native-adapter && npm publish -w packages/vue-adapter && npm publish -w packages/svelte-adapter",
    "demo:angular:form": "npm run -w @daltonr/pathwrite-demo-angular-form start",
    "demo:angular:wizard": "npm run -w @daltonr/pathwrite-demo-angular-wizard start",
    "demo:angular:subwizard": "npm run -w @daltonr/pathwrite-demo-angular-subwizard start",
    "demo:angular:skip": "npm run -w @daltonr/pathwrite-demo-angular-skip start",
    "demo:angular:stepchoice": "npm run -w @daltonr/pathwrite-demo-angular-stepchoice start",
    "demo:angular:storage": "npm run -w @daltonr/pathwrite-demo-angular-storage start",
    "demo:react:form": "npm run -w @daltonr/pathwrite-demo-react-form start",
    "demo:react:wizard": "npm run -w @daltonr/pathwrite-demo-react-wizard start",
    "demo:react:subwizard": "npm run -w @daltonr/pathwrite-demo-react-subwizard start",
    "demo:react:skip": "npm run -w @daltonr/pathwrite-demo-react-skip start",
    "demo:react:stepchoice": "npm run -w @daltonr/pathwrite-demo-react-stepchoice start",
    "demo:react:storage": "npm run -w @daltonr/pathwrite-demo-react-storage start",
    "demo:vue:form": "npm run -w @daltonr/pathwrite-demo-vue-form start",
    "demo:vue:wizard": "npm run -w @daltonr/pathwrite-demo-vue-wizard start",
    "demo:vue:subwizard": "npm run -w @daltonr/pathwrite-demo-vue-subwizard start",
    "demo:vue:skip": "npm run -w @daltonr/pathwrite-demo-vue-skip start",
    "demo:vue:course": "npm run -w @daltonr/pathwrite-demo-vue-course start",
    "demo:vue:storage": "npm run -w @daltonr/pathwrite-demo-vue-storage start",
    "demo:vue:stepchoice": "npm run -w @daltonr/pathwrite-demo-vue-stepchoice start",
    "demo:svelte:form": "npm run -w @daltonr/pathwrite-demo-svelte-form start",
    "demo:svelte:wizard": "npm run -w @daltonr/pathwrite-demo-svelte-wizard start",
    "demo:svelte:subwizard": "npm run -w @daltonr/pathwrite-demo-svelte-subwizard start",
    "demo:svelte:skip": "npm run -w @daltonr/pathwrite-demo-svelte-skip start",
    "demo:svelte:stepchoice": "npm run -w @daltonr/pathwrite-demo-svelte-stepchoice start",
    "demo:svelte:storage": "npm run -w @daltonr/pathwrite-demo-svelte-storage start",
    "demo:svelte:nested": "npm run -w @daltonr/pathwrite-demo-svelte-nested start",
    "demo:rn": "npm run -w @daltonr/pathwrite-demo-rn-showcase start"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.4",
    "@types/node": "^22.13.14",
    "fast-check": "^4.6.0",
    "svelte": "^5.54.1",
    "tsx": "^4.19.3",
    "typescript": "5.4.5",
    "vitest": "^3.0.8"
  }
}
