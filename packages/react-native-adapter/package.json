{
  "name": "@daltonr/pathwrite-react-native",
  "version": "0.8.0",
  "type": "module",
  "license": "MIT",
  "description": "React Native adapter for @daltonr/pathwrite-core — hooks, context provider, and optional PathShell default UI.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/richardadalton/pathwrite.git",
    "directory": "packages/react-native-adapter"
  },
  "keywords": [
    "wizard",
    "stepper",
    "path",
    "react-native",
    "hooks",
    "multi-step",
    "workflow",
    "ios",
    "android"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "prepublishOnly": "test -d dist && echo 'dist already built, skipping' || (npm run clean && npm run build)"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.72.0"
  },
  "dependencies": {
    "@daltonr/pathwrite-core": "^0.8.0"
  },
  "devDependencies": {
    "react": "^18.3.1",
    "@types/react": "^18.3.12",
    "react-native": "^0.76.0",
    "@testing-library/react": "^16.1.0",
    "jsdom": "^25.0.1"
  },
  "publishConfig": {
    "access": "public"
  }
}
