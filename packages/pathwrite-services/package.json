{
  "name": "@daltonr/pathwrite-services",
  "private": true,
  "version": "0.10.0",
  "description": "Service layer helpers for Pathwrite — defineServices wraps async functions with declarative caching, in-flight deduplication, retry, and prefetch.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "pathwrite",
    "wizard",
    "services",
    "cache",
    "prefetch",
    "retry"
  ],
  "author": "Richard Dalton",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/daltonr/pathwrite.git",
    "directory": "packages/pathwrite-services"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
