{
  "name": "@daltonr/pathwrite-react",
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "description": "React adapter for @daltonr/pathwrite-core — hooks, context provider, and optional <PathShell> default UI.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/richardadalton/pathwrite.git",
    "directory": "packages/react-adapter"
  },
  "keywords": ["wizard", "stepper", "path", "react", "hooks", "multi-step", "workflow"],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "dependencies": {
    "@daltonr/pathwrite-core": "^0.1.0"
  },
  "devDependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@testing-library/react": "^16.1.0",
    "jsdom": "^25.0.1"
  },
  "publishConfig": {
    "access": "public"
  }
}
