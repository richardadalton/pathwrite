{
  "name": "@daltonr/pathwrite-angular",
  "version": "0.5.0",
  "type": "module",
  "license": "MIT",
  "description": "Angular adapter for @daltonr/pathwrite-core — RxJS observables, signal-friendly, with optional <pw-shell> default UI.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/richardadalton/pathwrite.git",
    "directory": "packages/angular-adapter"
  },
  "keywords": [
    "wizard",
    "stepper",
    "path",
    "angular",
    "multi-step",
    "workflow"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./shell": {
      "types": "./dist/shell.d.ts",
      "import": "./dist/shell.js"
    },
    "./styles.css": "./dist/index.css"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "ngc -p tsconfig.json && cp ../shell.css dist/index.css",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "prepublishOnly": "test -d dist && echo 'dist already built, skipping' || (npm run clean && npm run build)"
  },
  "peerDependencies": {
    "@angular/core": ">=16.0.0",
    "@angular/common": ">=16.0.0",
    "@angular/forms": ">=16.0.0",
    "rxjs": "^7.0.0"
  },
  "peerDependenciesMeta": {
    "@angular/forms": {
      "optional": true
    }
  },
  "devDependencies": {
    "@angular/compiler": "^17.0.0",
    "@angular/compiler-cli": "^17.0.0"
  },
  "dependencies": {
    "@daltonr/pathwrite-core": "^0.5.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
