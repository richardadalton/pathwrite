{
  "name": "@daltonr/pathwrite-store",
  "version": "0.11.0",
  "description": "Persistence adapters for PathEngine — LocalStorageStore (browser), AsyncStorageStore (React Native / any async key-value store), and HttpStore (REST API)",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "pathwrite",
    "wizard",
    "persistence",
    "storage",
    "http",
    "localstorage",
    "async-storage",
    "react-native"
  ],
  "author": "Richard Dalton",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/daltonr/pathwrite.git",
    "directory": "packages/store"
  },
  "dependencies": {
    "@daltonr/pathwrite-core": "^0.11.0"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
