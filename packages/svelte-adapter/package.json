{
  "name": "@daltonr/pathwrite-svelte",
  "version": "0.4.0",
  "type": "module",
  "license": "MIT",
  "description": "Svelte adapter for @daltonr/pathwrite-core — stores with reactive bindings, and optional PathShell component.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/richardadalton/pathwrite.git",
    "directory": "packages/svelte-adapter"
  },
  "keywords": [
    "wizard",
    "stepper",
    "path",
    "svelte",
    "store",
    "multi-step",
    "workflow"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "import": "./dist/index.js"
    },
    "./PathShell.svelte": {
      "svelte": "./dist/PathShell.svelte",
      "import": "./dist/PathShell.svelte"
    },
    "./styles.css": "./dist/index.css"
  },
  "svelte": "./dist/index.js",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "mkdir -p dist && tsc -p tsconfig.json && cp ../shell.css dist/index.css && cp src/PathShell.svelte dist/PathShell.svelte",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "prepublishOnly": "test -d dist && echo 'dist already built, skipping' || (npm run clean && npm run build)"
  },
  "peerDependencies": {
    "svelte": ">=5.0.0"
  },
  "dependencies": {
    "@daltonr/pathwrite-core": "^0.4.0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@testing-library/svelte": "^5.0.0",
    "svelte": "^5.0.0"
  }
}

