{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "strict": true,
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "useDefineForClassFields": false,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": false,
    "baseUrl": ".",
    "paths": {
      "@daltonr/pathwrite-core": ["../../packages/core/src/index.ts"],
      "@daltonr/pathwrite-angular": ["../../packages/angular-adapter/src/index.ts"]
    }
  },
  "files": [],
  "include": ["src/**/*.ts"],
  "references": [
    { "path": "../../packages/core" },
    { "path": "../../packages/angular-adapter" }
  ]
}
